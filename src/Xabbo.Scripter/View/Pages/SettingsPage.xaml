<Page x:Class="Xabbo.Scripter.View.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Xabbo.Scripter.View.Pages"
      xmlns:viewModel="clr-namespace:Xabbo.Scripter.ViewModel"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="800"
      Title="Settings"
      Style="{StaticResource UiPage}"
      d:DataContext="{d:DesignInstance Type={x:Type viewModel:SettingsViewManager}}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,0,8,0">
        <StackPanel>
            <CheckBox
                IsChecked="{Binding DarkMode}"
                Content="Dark mode"
            />
            <CheckBox
                IsChecked="{Binding ShowUserName}"
                Content="Show username in status bar"
            />

            <Separator Margin="0,16,0,12" Opacity="0.4" />

            <TextBlock Text="AI MCP bridge" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,2" />
            <TextBlock Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,12"
                       Text="Lets AI through MCP connect to Scripter" />

            <StackPanel x:Name="McpSection">
                <!-- Status -->
                <Border Padding="12" CornerRadius="6" Margin="0,0,0,12"
                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,8,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="#9E9E9E" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Server.IsRunning}" Value="True">
                                                <Setter Property="Fill" Value="#4CAF50" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="{Binding Server.StatusText}" VerticalAlignment="Center" FontWeight="Medium" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Button Content="Start" Margin="0,0,8,0" Padding="14,4" Command="{Binding StartCommand}" />
                            <Button Content="Stop" Margin="0,0,8,0" Padding="14,4" Command="{Binding StopCommand}" />
                            <Button Content="Restart" Padding="14,4" Command="{Binding RestartCommand}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0" Opacity="0.8">
                            <TextBlock Text="Requests:" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Server.RequestCount}" Margin="0,0,16,0" />
                            <TextBlock Text="Sessions:" Margin="0,0,4,0" />
                            <TextBlock Text="{Binding Server.SessionCount}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Settings -->
                <CheckBox Content="Enable MCP server" IsChecked="{Binding Enabled}" />
                <CheckBox Content="Start automatically on launch" IsChecked="{Binding StartOnLaunch}" />
                <CheckBox Content="Require authentication token" IsChecked="{Binding RequireAuthToken}" />

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Port" VerticalAlignment="Center" Width="120" />
                    <TextBox Text="{Binding Port, UpdateSourceTrigger=LostFocus}" Width="100" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Endpoint" VerticalAlignment="Center" Width="120" />
                    <TextBox Text="{Binding Endpoint, Mode=OneWay}" IsReadOnly="True" Width="320" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="Token" VerticalAlignment="Center" Width="120" />
                    <TextBox Text="{Binding AuthToken, Mode=OneWay}" IsReadOnly="True" Width="320" />
                    <Button Content="Copy" Margin="8,0,0,0" Padding="10,2"
                            Command="{Binding CopyCommand}" CommandParameter="{Binding AuthToken}" />
                    <Button Content="Regenerate" Margin="8,0,0,0" Padding="10,2" Command="{Binding RegenerateTokenCommand}" />
                </StackPanel>

                <TextBlock Text="Capabilities" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,6" />
                <CheckBox Content="Allow running scripts" IsChecked="{Binding AllowExecute}" />
                <CheckBox Content="Allow saving / deleting script files" IsChecked="{Binding AllowFileWrite}" />
                <CheckBox Content="Allow editing visible editor tabs" IsChecked="{Binding AllowEditor}" />

                <!-- Integration -->
                <TextBlock Text="Connect a client" FontSize="14" FontWeight="SemiBold" Margin="0,16,0,2" />
                <TextBlock Opacity="0.7" TextWrapping="Wrap" Margin="0,0,0,8"
                           Text="Copy the command or config snippet and paste it into your client." />

                <ItemsControl ItemsSource="{Binding Clients}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="4" Margin="0,0,0,6"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" />
                                        <TextBlock Text="{Binding Hint}" Opacity="0.6" FontSize="11" TextWrapping="Wrap" Margin="0,1,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Copy" Padding="16,4" VerticalAlignment="Center"
                                            Command="{Binding DataContext.CopyClientCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Rectangle Height="16" Fill="Transparent" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
